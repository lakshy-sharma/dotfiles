[user]
	name  = Your Name
	email = you@example.com

[core]
	editor     = lvim
	pager      = delta
	autocrlf   = input

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[delta]
	navigate    = true      # n/N to jump between diff sections
	line-numbers = true
	side-by-side = true
	syntax-theme = Dracula

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[alias]
	st  = status -sb
	lg  = log --oneline --graph --decorate --all
	undo = reset --soft HEAD~1
	aliases = config --get-regexp alias
